# Credential for outbound FMP requests (required). The service reads the
# process environment directly and does not load this file automatically.
FMP_API_KEY=

# Comma-separated symbols to collect. Default: AAPL,NVDA,TSLA,MSFT,AMZN
#SYMBOLS=AAPL,MSFT

# Read-API listen address. Default: 127.0.0.1:8090
#LISTEN_ADDR=127.0.0.1:8090

# Local persistence root. Default: ./data
#DATA_DIR=./data

# Quote refresh cadence in minutes while running. Default: 15
#QUOTE_REFRESH_MINUTES=15

# Re-fetch profile/income/dividends when stored copy is older than this. Default: 24
#SLOW_REFRESH_HOURS=24
