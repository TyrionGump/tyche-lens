# Required credential for FMP requests.
FMP_API_KEY=

# Comma-separated US equity symbols. Default: AAPL,MSFT
#SYMBOLS=AAPL,MSFT

# HTTP listen address. Default: 127.0.0.1:8090
#LISTEN_ADDR=127.0.0.1:8090

# Local JSON snapshot. Default: ./data/quotes.json
#DATA_FILE=./data/quotes.json

# Quote refresh cadence. Default: 15
#QUOTE_REFRESH_MINUTES=15

# Override for tests or another FMP-compatible endpoint.
#FMP_BASE_URL=https://financialmodelingprep.com/stable
