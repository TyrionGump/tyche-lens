{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "import"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": ["src/api/generated/**", "src/api-mocks/generated/**"],
  "rules": {
    "import/no-cycle": [
      "error",
      {
        "ignoreTypes": false
      }
    ],
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "regex": "^@/app/shell/|^(?:\\.\\.?/)+(?:[^/]+/)*shell/",
            "message": "Import AppShell from \"@/app/shell\"; files below shell are internal."
          }
        ]
      }
    ]
  },
  "env": {
    "builtin": true
  }
}
